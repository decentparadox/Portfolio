---


import Base from '../layouts/Base.astro'
import '../styles/global.css'
import About from 'src/components/About/About.astro';
import Footer from '@/components/Footer/Footer.astro'
import Nav from 'src/components/Nav/Nav.astro'
import Projects from "src/components/Works/Project.astro"
import Hero from 'src/components/Hero/Hero.astro'

// Full Astro Component Syntax:
// https://docs.astro.build/core-concepts/astro-components/
---

<Base class="overflow-x-hidden ">
		<div class=" ">
			<Nav />
			<Hero />
			<About />
			<Projects />
			<Footer />
		</div>
</Base>

<script>
	import  Lenis  from "@studio-freight/lenis";
	const lenis = new Lenis({
    duration: 1.2,
    easing: (t:any) => (t === 1 ? 1 : 1 - Math.pow(2, -10 * t)),
    direction : "vertical",
    gestureDirection: "vertical",
    smooth: true,
    smoothTouch: true,
    touchMultiplier: 2,
}as never);

function raf(time:any) {
    lenis.raf(time);
    requestAnimationFrame(raf);
}

requestAnimationFrame(raf);
</script>

<style>
	.container{
		font-family: 'Geist';
	}
</style>
