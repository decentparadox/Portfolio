---
import Bodered from "@/layouts/Bodered.astro";
import { Image } from 'astro:assets';
import myimagedesign1 from 'public/about/img1.jpeg'
import myimagedesign2 from 'public/about/img2.jpeg'
import myimagedesign3 from 'public/about/img3.jpeg'
import myimagedesign4 from 'public/about/img4.jpeg'
import myimagedesign5 from 'public/about/img5.jpeg'
import myimagedesign6 from 'public/about/img6.jpeg'
import myimagedesign7 from 'public/about/img7.jpeg'
import myimagedesign8 from 'public/about/img8.jpeg'
import myimagedesign9 from 'public/about/img9.jpeg'
import myimagedesign10 from 'public/about/img10.jpeg'
import myimagedesign11 from 'public/about/img11.jpeg'
import myimagedesign12 from 'public/about/img12.jpeg'
import myimagedesign13 from 'public/about/img13.jpeg'
import myimagedesign14 from 'public/about/img14.jpeg'
import myimagedesign15 from 'public/about/img15.jpeg'
import myimagedesign16 from 'public/about/img16.jpeg'
import myimagedesign17 from 'public/about/img17.jpeg'
import myimagedesign18 from 'public/about/img18.jpeg'
import myimagedesign19 from 'public/about/img19.jpeg'
import myimagedesign20 from 'public/about/img20.jpeg'
---
<div class="w-[94%] ml-[3%] py-8">
    <Bodered class=" ">
        <div class="container w-[52%] ">
            <div class="indicator"></div>
            <div class="gallery">
              <div class="gallery-item">
                <Image src={myimagedesign1} alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign2} alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign3} alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign4} alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign5} alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign6} alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign7} alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign8} alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign9} alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign10} alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign11} alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign12} alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign13} alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign14}  alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign15}  alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign16}  alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign17}  alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign18}  alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign19}  alt="" />
              </div>
              <div class="gallery-item">
                <Image src={myimagedesign20}  alt="" />
              </div>
            </div>
          </div>
          <style>
            .container {
      position: relative;
      
      transform-origin: center;
      margin: 0 auto 2em auto;
      padding: 1em 0.5em;
      display: flex;
      justify-content: center;
    }
    
    .indicator {
      position: absolute;
      top: 0;
      left: 0;
      width: 5px;
      height: 5px;
      background: var(--foreground);
      border-radius: 100%;
      transition: all 1s cubic-bezier(0.075, 0.82, 0.165, 1);
    }
    
    .gallery {
      display: flex;
      justify-content: space-around;
      width: 100%;
      overflow: hidden;
    }
    
    .gallery-item {
      display: flex;
      justify-content: center;
      align-items: center;
      flex: 0 1 20px;
      height: 400px;
      margin: 0 5px;
      background: var(--background);
      overflow: hidden;
      transition: flex 1s cubic-bezier(0.075, 0.82, 0.165, 1);
    }
    
    .gallery-item img {
      width: 400px;
      height: 100%;
      object-fit: cover;
      transform: scale(1);
    }
    
          </style>
          <script>
            const galleryContainer:any = document.querySelector(".gallery");
    const galleryItems = galleryContainer.querySelectorAll(".gallery-item");
    const indicator:any = document.querySelector(".indicator");
    
    const defaultItemFlex = "0 1 20px";
    const hoverItemFlex = "1 1 400px";
    
    const updategalleryItems = () => {
      galleryItems.forEach((item:any) => {
        let flex = defaultItemFlex;
    
        if (item.isHovered) {
          flex = hoverItemFlex;
        }
    
        item.style.flex = flex;
      });
    };
    
    galleryItems[0].isHovered = true;
    updategalleryItems();
    
    galleryItems.forEach((item:any) => {
      item.addEventListener("mouseenter", () => {
        galleryItems.forEach((otherItem:any) => {
          otherItem.isHovered = otherItem === item;
        });
        updategalleryItems();
      });
    });
    
    galleryContainer.addEventListener("mousemove", (e:any) => {
      indicator.style.left = `${
        e.clientX - galleryContainer.getBoundingClientRect().left
      }px`;
    });
          </script>
    </Bodered>
</div>
